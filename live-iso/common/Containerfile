# run with --cap-add sys_admin --security-opt label=disable

ARG BASE_IMAGE
FROM ${BASE_IMAGE}

ARG LABEL="TunaOS-Live"
ARG DESKTOP_FLAVOR="gnome"
# Ref that Anaconda will install from (containers-storage).
# Must match the --bootc-installer-payload-ref passed to image-builder.
ARG PAYLOAD_REF=""

RUN --mount=type=bind,source=src,target=/src \
    LABEL="${LABEL}" DESKTOP_FLAVOR="${DESKTOP_FLAVOR}" PAYLOAD_REF="${PAYLOAD_REF}" /src/build.sh
