[Unit]
# Print a readiness marker to the serial console (ttyS0) once the live
# environment is fully usable. The e2e harness (scripts/iso-e2e.sh) polls a
# QEMU serial log for this string to know it can proceed with install / SSH
# tests.
#
# Writes DIRECTLY to /dev/ttyS0 via StandardOutput=tty + TTYPath, matching
# the dakota-iso pattern (DAKOTA_LIVE_READY). Using journal+console routes to
# /dev/console, which is NOT the serial port in headless QEMU (-display none).
#
# Ordering: After=livesys.service so liveuser exists and the live overlay is
# set up; After=NetworkManager-wait-online.service so DNS works for any
# follow-up step (flatpak remote check, package fetch, etc.); After=
# graphical.target on DE builds so gdm/sddm/greetd has actually started.
Description=TunaOS live environment ready marker
Documentation=https://github.com/tuna-os/tunaos/blob/main/docs/IMPROVEMENT_PLAN.md
After=livesys.service NetworkManager-wait-online.service graphical.target multi-user.target
Wants=NetworkManager-wait-online.service

[Service]
Type=oneshot
RemainAfterExit=yes
StandardOutput=tty
TTYPath=/dev/ttyS0
StandardError=tty
# Print twice to maximise the chance the harness sees it even if the serial
# device wasn't drained between writes. Including the boot time lets us
# correlate with the QEMU launch timestamp.
ExecStart=/bin/sh -c 'echo "TUNAOS_LIVE_READY uptime=$(awk "{print \\$1}" /proc/uptime)"'
ExecStart=/bin/sh -c 'sleep 2 && echo "TUNAOS_LIVE_READY uptime=$(awk "{print \\$1}" /proc/uptime)"'

[Install]
WantedBy=multi-user.target
