# Containerfile — Ubuntu 26.04 Resolute Raccoon → bootc image
#
# Produces: ghcr.io/tuna-os/ubuntu-bootc:26.04  (local: ubuntu-26.04-desktop-bootc)
#
# Two stages:
#   1. builder — compiles bootc from source (Rust)
#   2. final   — bootc-enabled Ubuntu with apt infrastructure intact
#
# Build:
#   podman build -t ubuntu-26.04-desktop-bootc:latest -f Containerfile .
#
# Key difference from the existing ghcr.io/hanthor/ubuntu-26.04-desktop-bootc
# image: this Containerfile does NOT run bootc-rootfs.sh or any apt-stripping
# step.  /var/lib/dpkg, /var/lib/apt/lists, /var/cache/apt/archives, and
# debconf remain intact so downstream Containerfiles can apt-get install.

# ── Stage 1: Build bootc from source ──────────────────────────────────────────
FROM rust:bookworm AS builder

ARG BOOTC_VERSION=v1.16.0

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        git \
        pkg-config \
        libssl-dev \
        && rm -rf /var/lib/apt/lists/*

RUN git clone --depth 1 --branch ${BOOTC_VERSION} \
    https://github.com/containers/bootc /build/bootc

WORKDIR /build/bootc
RUN cargo build --release --bin bootc && \
    strip target/release/bootc

# ── Stage 2: Ubuntu 26.04 with bootc ─────────────────────────────────────────
FROM ubuntu:resolute

# Install bootc runtime dependencies and desktop base packages.
# Keep all apt infrastructure intact — NO stripping.
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        # bootc runtime deps
        ostree \
        ostree-boot \
        bubblewrap \
        skopeo \
        # base system
        systemd \
        systemd-sysv \
        dbus \
        polkitd \
        # bootloader
        systemd-boot \
        # kernel
        linux-image-generic \
        # filesystem tools
        btrfs-progs \
        dosfstools \
        mtools \
        e2fsprogs \
        # networking
        network-manager \
        systemd-resolved \
        # container tools (for bootc install to-disk)
        podman \
        buildah \
    && apt-get clean

# Install bootc binary from builder
COPY --from=builder /build/bootc/target/release/bootc /usr/bin/bootc
RUN chmod +x /usr/bin/bootc

# Verify bootc is functional
RUN bootc --version

# Enable systemd as init
CMD ["/sbin/init"]
