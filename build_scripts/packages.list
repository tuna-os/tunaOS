# TunaOS Custom Packages List
# Format: package-name:version-release[:architecture]
#
# If architecture is omitted, the build script will auto-detect:
#   - x86_64_v2 for AlmaLinux Kitten
#   - x86_64 for standard AlmaLinux/CentOS
#   - aarch64 for ARM64
#
# Version can be "latest" to always pull the newest version
#
# Lines starting with # are comments

