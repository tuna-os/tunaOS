ARG BASE_IMAGE=ghcr.io/tuna-os/yellowfin:gnome@sha256:ed53c6e2ebc7b413a5a60484b402e871aba700a990b4e876fa03d90c76dbc699
FROM scratch AS ctx
COPY custom /custom
COPY build_scripts /build_scripts

FROM ${BASE_IMAGE}
RUN --mount=type=bind,from=ctx,src=/,target=/run/context \
    /run/context/build_scripts/apply-custom.sh
RUN bootc container lint
