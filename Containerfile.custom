ARG BASE_IMAGE=ghcr.io/tuna-os/yellowfin:gnome@sha256:a6a625d4f2ae26818d8cfd0d36578a7960eff80d0a51e72f0f4177f49fb67a86
FROM scratch AS ctx
COPY custom /custom
COPY build_scripts /build_scripts

FROM ${BASE_IMAGE}
RUN --mount=type=bind,from=ctx,src=/,target=/run/context \
    /run/context/build_scripts/apply-custom.sh
RUN bootc container lint
