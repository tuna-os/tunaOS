ARG BASE_IMAGE=ghcr.io/tuna-os/yellowfin:gnome@sha256:3fcec0ad17f5622644cac465d53c7da0f5996db40ef7f8a9c4cf3c3c39a1cc25
FROM scratch AS ctx
COPY custom /custom
COPY build_scripts /build_scripts

FROM ${BASE_IMAGE}
RUN --mount=type=bind,from=ctx,src=/,target=/run/context \
    /run/context/build_scripts/apply-custom.sh
RUN bootc container lint
